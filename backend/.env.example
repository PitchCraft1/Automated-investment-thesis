NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
PUBLIC_APP_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-different-long-random-secret

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/investment_thesis
MAX_UPLOADS_PER_HOUR=5

GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
REQUIRE_LLM_ANALYSIS=false

AWS_REGION=ap-south-1
S3_BUCKET_NAME=your_s3_bucket_name
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_SESSION_TOKEN=

EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
SMTP_FROM=no-reply@pitchdeckanalyzer.local

GOOGLE_OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

LINKEDIN_OAUTH_ENABLED=false
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=http://localhost:4000/api/auth/linkedin/callback
